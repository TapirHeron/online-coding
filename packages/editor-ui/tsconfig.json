{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@online-coding/shared": ["../shared/src"]
    },
    "rootDirs": ["./src", "../shared/src"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
