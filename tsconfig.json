{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@online-coding/shared": ["packages/shared/src"],
      "@online-coding/editor-core": ["packages/editor-core/src"],
      "@online-coding/language-support": ["packages/language-support/src"],
      "@online-coding/editor-ui": ["packages/editor-ui/src"]
    }
  },
  "include": ["apps/**/*", "packages/**/*"],
  "exclude": ["node_modules", "dist"]
}
